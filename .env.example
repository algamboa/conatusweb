# SMTP config (recommended for better deliverability)
SMTP_HOST=HOST
SMTP_PORT=465
SMTP_ENCRYPTION=smtps
SMTP_USERNAME=noreply@conatusweb.com
SMTP_PASSWORD=PASSWORD

MAIL_FROM_ADDRESS=noreply@conatusweb.com
MAIL_FROM_NAME=Conatus Web
MAIL_TO_ADDRESS=agamboa@conatusweb.com

# reCAPTCHA v3 secret key
RECAPTCHA_SITE_KEY=KEY
RECAPTCHA_SECRET=SECRET
RECAPTCHA_HOSTNAME=www.conatusweb.com

# Anti-abuso del formulario
CONTACT_RATE_LIMIT_MAX=8
CONTACT_RATE_LIMIT_WINDOW_SECONDS=3600
CONTACT_MIN_FILL_SECONDS=3
