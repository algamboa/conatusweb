DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
RewriteEngine On

# Keep old links working and consolidate to PHP entries
RewriteRule ^index\.html$ /index.php [R=301,L]
RewriteRule ^index-EN\.html$ /index-EN.php [R=301,L]
</IfModule>

# Compression for text-based resources.
<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml font/ttf font/otf
</IfModule>

# Browser caching for static assets.
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType text/css "access plus 1 month"
	ExpiresByType text/javascript "access plus 1 month"
	ExpiresByType application/javascript "access plus 1 month"
	ExpiresByType image/jpeg "access plus 1 year"
	ExpiresByType image/jpg "access plus 1 year"
	ExpiresByType image/png "access plus 1 year"
	ExpiresByType image/webp "access plus 1 year"
	ExpiresByType image/svg+xml "access plus 1 year"
	ExpiresByType image/x-icon "access plus 1 year"
	ExpiresByType font/woff2 "access plus 1 year"
	ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
	<FilesMatch "\.(css|js)$">
		Header set Cache-Control "public, max-age=2592000, immutable"
	</FilesMatch>
	<FilesMatch "\.(jpg|jpeg|png|webp|svg|ico|woff|woff2)$">
		Header set Cache-Control "public, max-age=31536000, immutable"
	</FilesMatch>
</IfModule>
